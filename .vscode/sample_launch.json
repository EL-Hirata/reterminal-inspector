{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: reTerminal Inspector",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "env": {
        "DISPLAY": ":0"
      }
    }
  ]
}